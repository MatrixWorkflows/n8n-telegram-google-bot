    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const query = $node[\"Recall Trigger\"].json.query || \"\";\n\nlet docText = \"\";\ntry {\n  const content = $json.body?.content;\n  if (content && Array.isArray(content)) {\n    docText = content\n      .map(block => {\n        if (block.paragraph && block.paragraph.elements) {\n          return block.paragraph.elements\n            .map(el => el.textRun?.content || \"\")\n            .join(\"\");\n        }\n        return \"\";\n      })\n      .join(\"\")\n      .trim();\n  }\n} catch(e) {\n  docText = \"Memory document could not be read.\";\n}\n\nreturn {\n  json: {\n    query: query,\n    full_memory: docText\n  }\n};"
      },
