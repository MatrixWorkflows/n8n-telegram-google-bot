    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "let docText = '';\nlet docEndIndex = 2;\ntry {\n  const content = $json.body?.content;\n  if (content && Array.isArray(content)) {\n    docText = content\n      .map(block => {\n        if (block.paragraph && block.paragraph.elements) {\n          return block.paragraph.elements\n            .map(el => el.textRun?.content || '')\n            .join('');\n        }\n        return '';\n      })\n      .join('')\n      .trim();\n    \n    // Get the actual end index from the document body\n    const lastElement = content[content.length - 1];\n    if (lastElement && lastElement.endIndex) {\n      docEndIndex = lastElement.endIndex;\n    } else {\n      docEndIndex = Math.max(docText.length + 1, 2);\n    }\n  }\n} catch(e) {}\n\nconst evalData = $node['Check Evaluation'].json;\n\nreturn {\n  json: {\n    current_memory: docText,\n    doc_end_index: docEndIndex,\n    evaluation: evalData.evaluation,\n    conversation_text: evalData.conversation_text\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
