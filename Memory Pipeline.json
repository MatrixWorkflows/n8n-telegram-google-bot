    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const newContent = $json.output || 'No memories yet.';\nconst docEndIndex = $node['Parse Current Memory'].json.doc_end_index || 2;\nconst docId = '1Z-H-5ocNfqFM-wOZugKpu47UfFH_J9YBEtHROZH7qJA';\n\nconst requests = [];\n\n// Delete existing content if there is any\nif (docEndIndex > 2) {\n  requests.push({\n    deleteContentRange: {\n      range: {\n        startIndex: 1,\n        endIndex: docEndIndex - 1\n      }\n    }\n  });\n}\n\n// Insert new content at the beginning\nrequests.push({\n  insertText: {\n    location: { index: 1 },\n    text: newContent\n  }\n});\n\nreturn {\n  json: {\n    url: 'https://docs.googleapis.com/v1/documents/' + docId + ':batchUpdate',\n    body: JSON.stringify({ requests: requests })\n  }\n};"
      },
