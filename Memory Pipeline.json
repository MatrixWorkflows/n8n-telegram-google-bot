      "parameters": {
        "jsCode": "const msgs = [...items].reverse();\nconst formatted = msgs.map(item => {\n  const parts = [];\n  if (item.json.user_input) parts.push('User: ' + item.json.user_input);\n  if (item.json.agent_output) parts.push('Cleo: ' + item.json.agent_output);\n  return parts.join('\\n');\n}).join('\\n\\n');\n\nreturn [{ json: { conversation_text: formatted, user_id: msgs[0]?.json?.user_id } }];"
      },
