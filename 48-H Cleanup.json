        "jsCode": "let docText = \"\";\ntry {\n  const content = $json.body?.content;\n  if (content && Array.isArray(content)) {\n    docText = content\n      .map(block => {\n        if (block.paragraph && block.paragraph.elements) {\n          return block.paragraph.elements\n            .map(el => el.textRun?.content || \"\")\n            .join(\"\");\n        }\n        return \"\";\n      })\n      .join(\"\")\n      .trim();\n  }\n} catch(e) {}\n\nreturn { json: { memory_text: docText } };"
