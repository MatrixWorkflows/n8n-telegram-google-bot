        "jsCode": "const draft = $json.output || $json;\nconst orig = $node['Format Draft Preview'].json;\n\nconst draftSubject = draft.subject || orig.subject;\nconst draftBody = draft.body || '';\n\nconst previewText = `📧 Revised Draft\\n\\nTo: ${orig.to_email}\\nSubject: ${draftSubject}\\n\\n---\\n${draftBody}\\n---`;\n\nreturn {\n  json: {\n    ...orig,\n    previewText,\n    subject: draftSubject,\n    draft_body: draftBody\n  }\n};"
