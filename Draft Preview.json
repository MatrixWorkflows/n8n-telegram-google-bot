        "jsCode": "const d = $node['Find Pending Drafts'].json;\n\nconst toEmail = d.to_email || 'Unknown';\nconst subject = d.subject || '(no subject)';\nconst body = d.draft_body || '';\nconst replyToId = d.reply_to_id || '';\nconst draftId = d.draftId || '';\n\nconst previewText = `📧 Draft Ready\\n\\nTo: ${toEmail}\\nSubject: ${subject}\\n\\n---\\n${body}\\n---`;\n\nreturn {\n  json: {\n    previewText,\n    draftId,\n    to_email: toEmail,\n    subject,\n    draft_body: body,\n    reply_to_id: replyToId\n  }\n};"
